# This is the Base API URL for your frontend to communicate with your backend.
# For local development:
VITE_API_BASE_URL=http://localhost:5000/api

# For Render / Production deployments, configure this environment variable
# directly in your Render static site dashboard.
# Example:
VITE_API_BASE_URL=https://onboardingapp-renderdeployment-backend.onrender.com/api
